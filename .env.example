# ============================================================
# BondEx 環境変数テンプレート
# ------------------------------------------------------------
# このファイルは「変数名の一覧」です。実際の値は入っていません。
# 別 PC では以下のどちらかで .env.local を用意してください:
#
#   (推奨) Vercel から一括取得:
#     npm i -g vercel && vercel login && vercel link
#     vercel env pull .env.local
#
#   (手動) このファイルを .env.local にコピーして値を埋める:
#     cp .env.example .env.local   ← 値は Vercel の Project Settings → Environment Variables から
#
# 注意: .env* は .gitignore 済み。秘密情報は絶対にコミットしない。
# ============================================================

# ---------- 必須 (これが無いと主要機能が動かない) ----------

# AI 旅程パース / 住所検証 (Anthropic)
ANTHROPIC_API_KEY=

# ホテル名の自動検索 (Google Places)
GOOGLE_MAPS_API_KEY=

# データベース / ダッシュボード / 追跡 (Supabase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 送り状発行 (Ship&co・佐川/ヤマト)
SHIPANDCO_API_KEY=

# 送り状のご依頼主(集荷連絡先)TEL を固定する。未設定なら発送元ホテルの電話→なければ 0 埋め。
# 例: 09012345678 (ハイフンなし)。BondEx の集荷窓口番号が決まったらここに設定。
BONDEX_SENDER_PHONE=

# /operator の簡易認証ゲート (未設定だと本番は 503。ローカルは素通り)
OPERATOR_PASSWORD=

# 追跡同期 cron (GitHub Actions) の Bearer 認証
CRON_SECRET=

# ---------- 任意 (機能ごとに設定。未設定でもアプリは動く) ----------

# 配送アラートのメール送信 (Resend)。未設定だと console ログのみ
RESEND_API_KEY=
ALERT_EMAIL=            # 既定 support@bondex.express
ALERT_FROM_EMAIL=      # 既定 "BondEx Alerts <alerts@bondex.express>"

# 配送アラートの Slack 通知。未設定だと Slack へは飛ばさない
SLACK_WEBHOOK_URL=

# 書類の Google 共有ドライブ格納 (バウチャー+送り状を予約番号フォルダへ)。両方セットで有効化。
# 未設定なら「Driveへ格納」は 503 で無効 (手動運用にフォールバック)。
#   GOOGLE_DRIVE_SA_KEY  … サービスアカウントの JSON 鍵 (生 JSON か base64)。※秘密
#   GOOGLE_DRIVE_ROOT_ID … 格納先「共有ドライブ」の ID (0A で始まる)。※共有ドライブ必須
GOOGLE_DRIVE_SA_KEY=
GOOGLE_DRIVE_ROOT_ID=

# 問い合わせ QR の宛先。設定すると WhatsApp、未設定は mailto:support@ にフォールバック
#   例: https://wa.me/81XXXXXXXXXX
BONDEX_WHATSAPP_URL=

# 決済 — 代理店のカード保存 (Stripe)。両方セットで有効化。未設定でも登録は動くが
# カード登録は「準備中」表示にフォールバックする。
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# レート制限の調整 (未設定は既定値)
RATE_LIMIT_PER_MINUTE=

# Ship&co テストモードのフラグ表示 (フロント用)
NEXT_PUBLIC_SHIPANDCO_TEST=

# ▼▼ 本番発行スイッチ (最重要・お金がかかる) ▼▼
# 実際の送り状発行 (課金・実集荷・取消不可) を有効化する。
#   未設定 / 空 / "true" 以外 → 必ずテスト (test:true・無料・集荷なし)  ← 安全側の既定
#   厳密に "true" のときだけ → 本番 (実ラベル発行)
# 本番化: Vercel で SHIPANDCO_LIVE=true を設定して再デプロイ。戻すときは削除 or false。
SHIPANDCO_LIVE=
