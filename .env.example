# ============================================================
# BondEx 環境変数テンプレート
# ------------------------------------------------------------
# このファイルは「変数名の一覧」です。実際の値は入っていません。
# 別 PC では以下のどちらかで .env.local を用意してください:
#
#   (推奨) Vercel から一括取得:
#     npm i -g vercel && vercel login && vercel link
#     vercel env pull .env.local
#
#   (手動) このファイルを .env.local にコピーして値を埋める:
#     cp .env.example .env.local   ← 値は Vercel の Project Settings → Environment Variables から
#
# 注意: .env* は .gitignore 済み。秘密情報は絶対にコミットしない。
# ============================================================

# ---------- 必須 (これが無いと主要機能が動かない) ----------

# AI 旅程パース / 住所検証 (Anthropic)
ANTHROPIC_API_KEY=

# ホテル名の自動検索 (Google Places)
GOOGLE_MAPS_API_KEY=

# データベース / ダッシュボード / 追跡 (Supabase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ヤマト送り状発行 (Ship&co)
SHIPANDCO_API_KEY=

# /operator の簡易認証ゲート (未設定だと本番は 503。ローカルは素通り)
OPERATOR_PASSWORD=

# 追跡同期 cron (GitHub Actions) の Bearer 認証
CRON_SECRET=

# ---------- 任意 (機能ごとに設定。未設定でもアプリは動く) ----------

# 配送アラートのメール送信 (Resend)。未設定だと console ログのみ
RESEND_API_KEY=
ALERT_EMAIL=            # 既定 support@bondex.express
ALERT_FROM_EMAIL=      # 既定 "BondEx Alerts <alerts@bondex.express>"

# 配送アラートの Slack 通知。未設定だと Slack へは飛ばさない
SLACK_WEBHOOK_URL=

# 問い合わせ QR の宛先。設定すると WhatsApp、未設定は mailto:support@ にフォールバック
#   例: https://wa.me/81XXXXXXXXXX
BONDEX_WHATSAPP_URL=

# 決済 — 代理店のカード保存 (Stripe)。両方セットで有効化。未設定でも登録は動くが
# カード登録は「準備中」表示にフォールバックする。
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# レート制限の調整 (未設定は既定値)
RATE_LIMIT_PER_MINUTE=

# Ship&co テストモードのフラグ表示 (フロント用)
NEXT_PUBLIC_SHIPANDCO_TEST=
